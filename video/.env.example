# =============================================================================
# Telegram API Credentials (for Telethon userbot / scraper)
# =============================================================================
API_ID=12345678
API_HASH=your_api_hash_here
PHONE_NUMBER=+1234567890

# =============================================================================
# Bot Tokens
# =============================================================================
# Main Bot: Handles /start, membership, redirects (NEVER sends media)
MAIN_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Delivery Bot: Sends videos via copy_message() (isolated, replaceable)
DELIVERY_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew22

# =============================================================================
# Channel IDs (use actual numeric IDs with -100 prefix)
# =============================================================================
# Private source channel containing TaraBox links
SOURCE_CHANNEL=-1001234567890

# Private archive channel where videos are stored
ARCHIVE_CHANNEL=-1001234567891

# =============================================================================
# Converter Bot
# =============================================================================
# Username of the third-party converter bot (without @)
CONVERTER_BOT=example_converter_bot

# =============================================================================
# Security
# =============================================================================
# Secret key for signing tokens (generate with: openssl rand -hex 32)
TOKEN_SECRET=your_32_byte_hex_secret_here

# Token expiry time in minutes
TOKEN_EXPIRY_MINUTES=10

# =============================================================================
# Rate Limiting
# =============================================================================
# Max requests per user per hour
RATE_LIMIT_PER_HOUR=10

# =============================================================================
# Scraping
# =============================================================================
# How often to check for new messages (seconds)
SCRAPE_INTERVAL=60
